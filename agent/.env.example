# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                  # optional fallback

# TradingAgents upstream env overrides
TRADINGAGENTS_LLM_PROVIDER=anthropic
TRADINGAGENTS_DEEP_THINK_LLM=claude-opus-4-7
TRADINGAGENTS_QUICK_THINK_LLM=claude-sonnet-4-6
TRADINGAGENTS_OUTPUT_LANGUAGE=English
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1

# US data
POLYGON_API_KEY=...
FINNHUB_API_KEY=...
SEC_EDGAR_USER_AGENT="Trading Research canberk@example.com"

# Sentiment
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT="trading-research/0.1"
X_BEARER_TOKEN=...

# Macro
FRED_API_KEY=...

# Brokers
ALPACA_API_KEY=...
ALPACA_API_SECRET=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# AWS
AWS_PROFILE=rootingo
AWS_REGION=eu-west-1

# Storage
S3_DATA_BUCKET=ai-trader-data-dev
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/trader

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Risk
MAX_DAILY_DRAWDOWN=0.03
MAX_POSITION_PCT=0.10
MAX_SECTOR_PCT=0.30
KILL_SWITCH_POLL_INTERVAL_SECONDS=5
