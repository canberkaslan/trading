{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-dev.trading.canberkaslan.co"
      }
    },
    "paper": {
      "distribution": "internal",
      "channel": "paper",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-paper.trading.canberkaslan.co"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.trading.canberkaslan.co"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
